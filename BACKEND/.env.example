# DIR = .envs/local/

# ------------------------------------------------------------------------------
# PostgreSQL .postgres
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=foodguard_api
POSTGRES_USER=example
POSTGRES_PASSWORD=example

# ------------------------------------------------------------------------------
# Github .git_config
# ------------------------------------------------------------------------------
GIT_USER_NAME="example"
GIT_USER_EMAIL="example@email.com"

# ------------------------------------------------------------------------------
# Django .django
# ------------------------------------------------------------------------------
# Gere uma nova chave com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=sua_secret_key_aqui

GEMINI_API_KEY=sua_chave_aqui

# Seleção do provedor de IA: "gemini" | "openai"
AI_PROVIDER=gemini

# OpenAI (usado quando AI_PROVIDER=openai)
OPENAI_API_KEY=sua_chave_aqui
OPENAI_MODEL_NAME=gpt-4o
OPENAI_TEMPERATURE=0.7